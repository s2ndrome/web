#preview {

  width: 420px;
  height: 600px;

  background: white;

  border-radius: 30px;

  padding: 40px;

  display: flex;
  flex-direction: column;

  justify-content: center;

  align-items: center;

  text-align: center;
}

#previewQuote {

  font-size: 28px;
  line-height: 1.8;
  white-space: pre-wrap;
}

#previewInfo {

  margin-top: 40px;

  font-size: 14px;

  opacity: 0.6;
}
